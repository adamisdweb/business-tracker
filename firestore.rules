rules_version = '2';
// ===========================================================================
//  Firestore security rules — paste into Firebase console → Firestore → Rules.
//  Every document lives under users/{uid}. A signed-in user can ONLY read and
//  write their own subtree. Nobody can touch anyone else's data, and signed-
//  out requests are rejected entirely.
// ===========================================================================
service cloud.firestore {
  match /databases/{database}/documents {
    // Only this one Google account may read or write anything.
    function isOwner(userId) {
      return request.auth != null
        && request.auth.uid == userId
        && request.auth.token.email == 'adammounir1111@gmail.com';
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
